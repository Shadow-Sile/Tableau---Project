      <aliases enabled='yes' />
      <column caption='Avg Revenue' datatype='integer' name='[Calculation_2081983183273985]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[price]* (365 - [availability_365])&#13;&#10;&#13;&#10;//Price per night × days occupied per year. &#13;&#10;//How much money each listing makes annually.' />
      </column>
      <column caption='Tax Occupation %' datatype='real' name='[Calculation_2081983183732738]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(365 - [availability_365]) / 365 * 100&#13;&#10;&#13;&#10;//What % of the year the listing is booked.' />
      </column>
      <column caption='Price per Guest' datatype='real' name='[Calculation_2081983185014787]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[price] / [accommodates]&#13;&#10;&#13;&#10;// Price divided by number of guests. &#13;&#10;//Lets you compare listings euqally.' />
      </column>
